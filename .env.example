# ============================================================
#  LeadForge — Root Environment Variables
#  Copy this file to .env and fill in actual values.
#  NEVER commit .env to version control.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=leadforge
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_strong_password_here

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Backend App ──────────────────────────────────────────────
APP_ENV=production
APP_SECRET_KEY=change_me_random_secret_here
API_KEY=change_me_dashboard_api_key_here
FRONTEND_ORIGIN=https://preview.yourdomain.com

# ── AI APIs ──────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GOOGLE_PLACES_API_KEY=AIza...
GOOGLE_AI_API_KEY=AIza...
APIFY_API_TOKEN=apify_api_...

# ── LangSmith (optional tracing) ─────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=leadforge

# ── Preview URL (embedded in wa.me messages) ─────────────────
# After VPS deploy, update to your live subdomain:
PREVIEW_BASE_URL=https://preview.yourdomain.com

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Frontend (consumed by Next.js Docker container) ──────────
BACKEND_INTERNAL_URL=http://api:8000
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
